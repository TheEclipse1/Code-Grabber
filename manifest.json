{
  "manifest_version": 3,
  "name": "Code Grabber",
  "version": "1.0.0",
  "description": "Watches your Gmail for verification codes and offers to fill them into the page you're on.",
  "permissions": [
    "identity",
    "storage",
    "alarms",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://gmail.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Code Grabber"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "oauth2": {
    "client_id": "1063956328855-9h7kvhf1f4jgma9fjrasfm9oesvuusv4.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  }
}
